{
  "name": "afonsojramos.me",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "db:migrate:local": "wrangler d1 migrations apply afonsojramos-me-views --local",
    "dev": "bun run db:migrate:local && astro dev",
    "dev:network": "bun run db:migrate:local && astro dev --host",
    "build": "astro check && astro build && bun scripts/rasterize-covers.ts",
    "preview": "wrangler pages dev ./dist --port 4321",
    "preview:network": "astro preview --host",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "13.7.0",
    "@astrojs/mdx": "6.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/solid-js": "6.0.1",
    "@fontsource/inter-tight": "^5.2.7",
    "@kobalte/core": "^0.13.11",
    "@kobalte/tailwindcss": "^0.9.0",
    "@markdoc/markdoc": "^0.5.7",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "6.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-solid": "^8.6.0",
    "hono": "^4.12.27",
    "husky": "^9.1.7",
    "sharp": "^0.35.2",
    "solid-js": "^1.9.13",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@resvg/resvg-js": "^2.6.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "wawoff2": "^2.0.1"
  }
}

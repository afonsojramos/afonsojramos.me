{
  "name": "afonsojramos.me",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "contributions:update": "nub scripts/update-contributions.ts",
    "db:migrate:local": "wrangler d1 migrations apply afonsojramos-me-views --local",
    "dev": "nub run db:migrate:local && astro dev",
    "dev:network": "nub run db:migrate:local && astro dev --host",
    "build": "astro check && astro build && nub scripts/rasterize-covers.ts",
    "preview": "wrangler pages dev ./dist --port 4321",
    "preview:network": "astro preview --host",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "14.1.1",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/solid-js": "7.0.1",
    "@fontsource/inter-tight": "^5.2.7",
    "@kobalte/core": "^0.13.12",
    "@kobalte/tailwindcss": "^0.9.0",
    "@markdoc/markdoc": "^0.5.7",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "7.0.6",
    "blockrate": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-solid": "^8.6.0",
    "hono": "^4.12.27",
    "husky": "^9.1.7",
    "sharp": "^0.35.3",
    "solid-js": "^1.9.14",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "unstorage": "^1.17.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260703.1",
    "@nubjs/nub": "0.4.11",
    "@resvg/resvg-js": "^2.6.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "wawoff2": "^2.0.1"
  }
}

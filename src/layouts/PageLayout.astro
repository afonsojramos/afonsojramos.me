---
import Footer from "~/components/Footer.astro";
import Head from "~/components/Head.astro";
import Header from "~/components/Header.astro";
import { SITE } from "~/consts";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
};

const { title, description, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      title={title === "home" ? SITE.name : `${title} | ${SITE.name}`}
      description={description}
      image={image}
      noindex={noindex}
    />
  </head>
  <body>
    <Header />
    <main class="print:p-0 print:text-black">
      <slot />
    </main>
    <Footer />
    <script>
      import { BlockRate } from "blockrate";

      // Measures which analytics providers ad blockers block for visitors of
      // this site and reports to the same-origin /api/block-rate route (which
      // forwards server-side to blockrate.app). Consent-free: no cookies, no
      // storage, no identifiers — see https://blockrate.app.
      new BlockRate({
        providers: [
          "amplitude",
          "ga4",
          "gtm",
          "hotjar",
          "intercom",
          "meta-pixel",
          "mixpanel",
          "optimizely",
          "posthog",
          "segment",
        ],
        service: "afonsojramos.me",
        reporter: (result) => {
          navigator.sendBeacon("/api/block-rate", JSON.stringify(result));
        },
      }).check();
    </script>
  </body>
</html>

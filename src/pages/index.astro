---
export const prerender = true;

import { getCollection } from "astro:content";
import Container from "~/components/Container.astro";
import HoverLink from "~/components/hover-card/HoverLink.astro";
import Link from "~/components/Link.astro";
import PostCard from "~/components/PostCard.astro";
import WorkCard from "~/components/WorkCard.astro";
import { HOME, SITE, SOCIALS } from "~/consts";
import PageLayout from "~/layouts/PageLayout.astro";
import { sortByDate, sortByDateRange } from "~/lib/utils";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(sortByDate)
  .slice(0, SITE.numPostsOnHomepage);

const work = (await getCollection("work"))
  .sort(sortByDateRange)
  .slice(0, SITE.numWorksOnHomepage);

const seeAllClass =
  "title-render text-[#3b29ff] hover:text-[#2a1fd6] dark:text-[#9b94ff] dark:hover:text-[#b7b1ff]";
---

<PageLayout {...HOME}>
  <div class="space-y-16">
    <Container>
      <section>
        <img
          src="/afonso.jpg"
          alt="Afonso Jorge Ramos"
          class="animate size-14 rounded-full object-cover"
        />
        <article class="mt-4 space-y-4 text-black dark:text-white">
          <p class="title-render animate">
            I'm a product-minded software engineer,{" "}
            <HoverLink
              href="https://github.com/afonsojramos"
              label="Afonso Ramos on Github"
            >
              open-source enthusiast
            </HoverLink>, music lover, and front-row concertgoer. A{" "}
            <HoverLink
              href="https://untappd.com/user/afonsojramos"
              label="Afonso Ramos on Untappd"
            >
              craft beer afficionado
            </HoverLink>{" "}
            and natural wanderer, always exploring new ideas and experiences.
          </p>
          <p class="title-render animate">
            Currently leading{" "}
            <HoverLink href="https://www.bpp.com" label="BPP website">
              BPP's
            </HoverLink>{" "}
            mobile modernisation (via{" "}
            <HoverLink href="https://www.yld.io" label="YLD website">
              YLD
            </HoverLink>), rebuilding how 30,000+ learners access their courses through a new
            React Native app, tutor platform, and the services behind them.
          </p>
        </article>
      </section>
    </Container>

    <section class="animate space-y-6">
      <div class="mx-auto flex w-full max-w-2xl flex-wrap items-center justify-between gap-y-2 px-5">
        <h5 class="font-semibold text-black dark:text-white">Blog</h5>
        <Link
          href="/blog"
          underline={false}
          class={seeAllClass}
        >
          See all posts
        </Link>
      </div>
      <ul class="mx-auto grid w-full max-w-[1288px] grid-cols-1 gap-4 px-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          blog.map((post) => (
            <li>
              <PostCard entry={post} />
            </li>
          ))
        }
      </ul>
    </section>

    <Container>
      <div class="space-y-16">
        <section class="animate space-y-6">
          <div class="flex flex-wrap gap-y-2 items-center justify-between">
            <h5 class="font-semibold text-black dark:text-white">Work</h5>
            <Link
              href="/work"
              underline={false}
              class={seeAllClass}
            >
              See all experience
            </Link>
          </div>
          <ul class="flex flex-col space-y-4">
            {
              work.map((entry) => (
                <li>
                  <WorkCard entry={entry} />
                </li>
              ))
            }
          </ul>
        </section>

          <section class="animate space-y-4" id="contacts">
            <h5 class="font-semibold text-black dark:text-white">Get in Touch 👋</h5>
            <article>
              <p>
                If you want to get in touch with me about something or just to say
                hi, reach out on social media or send me an email.
              </p>
            </article>
            <ul class="flex flex-wrap gap-2">
              {
                SOCIALS.map((SOCIAL, index) => (
                  <li class="flex gap-x-2 text-nowrap">
                    <HoverLink href={SOCIAL.href} label={`${SITE.name} on ${SOCIAL.name}`}>
                    {SOCIAL.name}
                  </HoverLink>
                    {index !== SOCIALS.length - 1 && " / "}
                  </li>
                ))
              }
            </ul>
          </section>
      </div>
    </Container>
  </div>
</PageLayout>

---
export const prerender = true;

import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrev from "~/components/BackToPrev.astro";
import Container from "~/components/Container.astro";
import FormattedDate from "~/components/FormattedDate.astro";
import Link from "~/components/Link.astro";
import ViewCount from "~/components/ViewCount.astro";
import PageLayout from "~/layouts/PageLayout.astro";
import { readingTime } from "~/lib/utils";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await render(project);
---

<PageLayout
  title={project.data.title}
  description={project.data.description}
  image={`/${project.collection}/${project.id}.png`}
>
  <Container>
    <div class="animate">
      <BackToPrev href="/work"> Back to work </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="title-render animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={project.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(project.body)}
        </div>
        <ViewCount slug={`projects/${project.id}/`} />
      </div>
      <div class="animate flex items-center gap-3">
        <div class="title-render text-2xl font-semibold text-black dark:text-white">
          {project.data.title}
        </div>
        {
          project.data.icon &&
            (() => {
              const isSvg = project.data.icon.format === "svg";
              const inner = isSvg ? (
                <img
                  src={project.data.icon.src}
                  alt=""
                  width={project.data.iconBackground ? 32 : 40}
                  height={project.data.iconBackground ? 32 : 40}
                />
              ) : (
                <Image
                  src={project.data.icon}
                  alt=""
                  width={project.data.iconBackground ? 32 : 40}
                  height={project.data.iconBackground ? 32 : 40}
                />
              );
              return project.data.iconBackground ? (
                <div
                  class="ml-auto flex items-center justify-center rounded-md shrink-0 size-10"
                  style={`background: ${project.data.iconBackground}`}
                >
                  {inner}
                </div>
              ) : (
                <div class="ml-auto rounded-md shrink-0 overflow-hidden">{inner}</div>
              );
            })()
        }
      </div>
      {
        (project.data.demoURL || project.data.repoURL) && (
          <nav class="animate flex gap-1">
            {project.data.demoURL && (
              <Link href={project.data.demoURL} external>
                demo
              </Link>
            )}
            {project.data.demoURL && project.data.repoURL && <span>/</span>}
            {project.data.repoURL && (
              <Link href={project.data.repoURL} external>
                repo
              </Link>
            )}
          </nav>
        )
      }
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>

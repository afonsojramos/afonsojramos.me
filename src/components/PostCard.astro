---
import type { CollectionEntry } from "astro:content";
import { readingTime } from "~/lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
};

const { entry } = Astro.props;
const tags = entry.data.tags ?? [];
const visibleTags = tags.slice(0, 2);
const extraTags = tags.length - visibleTags.length;
---

<a
  href={`/blog/${entry.id}`}
  class="group flex h-full flex-col gap-2 rounded-xl bg-white p-5 no-underline transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:bg-white/5 dark:hover:bg-white/10 dark:hover:text-white"
>
  <div
    class="title-render font-semibold text-black dark:text-white"
    transition:name={`post-title-${entry.id}`}
  >
    {entry.data.title}
  </div>
  <div class="title-render text-sm line-clamp-3">
    {entry.data.description}
  </div>
  <div class="mt-auto flex items-center justify-between gap-2 pt-3 text-xs">
    <div class="flex gap-1.5">
      {
        visibleTags.map((tag) => (
          <span class="rounded-full bg-[#f5f5f5] px-2 py-0.5 text-nowrap text-black dark:bg-white/10 dark:text-white">
            {tag}
          </span>
        ))
      }
      {
        extraTags > 0 && (
          <span class="rounded-full bg-[#f5f5f5] px-2 py-0.5 text-black dark:bg-white/10 dark:text-white">+{extraTags}</span>
        )
      }
    </div>
    <span class="text-nowrap text-black/50 dark:text-white/50">{readingTime(entry.body)}</span>
  </div>
</a>

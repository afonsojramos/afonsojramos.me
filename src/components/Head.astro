---
import "../styles/global.css";
import "@fontsource/inter-tight/400.css";
import "@fontsource/inter-tight/600.css";
import { ClientRouter } from "astro:transitions";
import interTight400 from "@fontsource/inter-tight/files/inter-tight-latin-400-normal.woff2";
import interTight600 from "@fontsource/inter-tight/files/inter-tight-latin-600-normal.woff2";
import { SITE } from "~/consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = "/nano.png", noindex = false } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link
  rel="icon"
  type="image/svg+xml"
  href="/favicon.svg"
  media="(prefers-color-scheme: dark)"
/>
<link
  rel="icon"
  type="image/svg+xml"
  href="/favicon.svg"
  media="(prefers-color-scheme: light)"
/>
<link rel="icon" type="image/x-icon" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Font preloads -->
<link
  rel="preload"
  href={interTight400}
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href={interTight600}
  as="font"
  type="font/woff2"
  crossorigin
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE.name}
  href={new URL("/rss.xml", Astro.site)}
/>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<ClientRouter />

<script>
  import type { TransitionBeforeSwapEvent } from "astro:transitions/client";
  document.addEventListener("astro:before-swap", (e) =>
    [
      ...(e as TransitionBeforeSwapEvent).newDocument.head.querySelectorAll(
        'link[as="font"]'
      ),
    ].forEach((link) => link.remove())
  );
</script>

<script is:inline>
  function init() {
    const scrolled = window.scrollY > 0;

    preloadTheme();
    updateScrollState(scrolled);
    animate();

    window.siteEventController?.abort();
    const controller = new AbortController();
    const { signal } = controller;
    window.siteEventController = controller;

    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", scrollToTop, { signal });

    const backToPrev = document.getElementById("back-to-prev");
    backToPrev?.addEventListener("click", goBack, { signal });

    const lightThemeButton = document.getElementById("light-theme-button");
    lightThemeButton?.addEventListener("click", useLightTheme, { signal });

    const darkThemeButton = document.getElementById("dark-theme-button");
    darkThemeButton?.addEventListener("click", useDarkTheme, { signal });

    const systemThemeButton = document.getElementById("system-theme-button");
    systemThemeButton?.addEventListener("click", useSystemTheme, { signal });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", handleSystemThemeChange, { signal });

    document.addEventListener("keydown", handleShortcut, { signal });
    document.addEventListener("scroll", onScroll, { passive: true, signal });
  }

  function goBack(event) {
    if (window.history.length > 1) {
      event.preventDefault();
      window.history.back();
    }
  }

  function useLightTheme() {
    localStorage.setItem("theme", "light");
    toggleTheme(false);
  }

  function useDarkTheme() {
    localStorage.setItem("theme", "dark");
    toggleTheme(true);
  }

  function useSystemTheme() {
    localStorage.setItem("theme", "system");
    toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
  }

  function handleSystemThemeChange(event) {
    if (localStorage.theme === "system") {
      toggleTheme(event.matches);
    }
  }

  function handleShortcut(event) {
    const activeElement = document.activeElement;
    const isEditing =
      activeElement instanceof HTMLElement &&
      (activeElement.isContentEditable ||
        ["INPUT", "TEXTAREA", "SELECT"].includes(activeElement.tagName));

    // Site shortcuts are bare keys. Preserve copy/paste, browser shortcuts,
    // and normal typing in form fields or contenteditable elements.
    if (
      isEditing ||
      event.metaKey ||
      event.ctrlKey ||
      event.altKey ||
      event.shiftKey
    ) {
      return;
    }

    switch (event.key) {
      case "t":
        event.preventDefault();
        cycleTheme();
        break;
      case "h":
        event.preventDefault();
        window.location.href = "/";
        break;
      case "b":
        event.preventDefault();
        window.location.href = "/blog";
        break;
      case "m":
        event.preventDefault();
        window.location.href = "/music";
        break;
      case "c":
        event.preventDefault();
        if (window.location.pathname === "/") {
          document
            .getElementById("contacts")
            ?.scrollIntoView({ behavior: "smooth" });
        } else {
          window.location.href = "/#contacts";
        }
        break;
      case "ArrowLeft":
      case "ArrowRight": {
        const postNav = document.getElementById("post-nav");
        const target =
          event.key === "ArrowLeft"
            ? postNav?.dataset.newer
            : postNav?.dataset.older;
        if (target) {
          event.preventDefault();
          window.location.href = target;
        }
        break;
      }
    }
  }

  function animate() {
    const animateElements = document.querySelectorAll(".animate");

    animateElements.forEach((element, index) => {
      setTimeout(() => {
        element.classList.add("show");
      }, index * 150);
    });
  }

  function onScroll() {
    updateScrollState(window.scrollY > 0);
  }

  function updateScrollState(scrolled) {
    document.documentElement.classList.toggle("scrolled", scrolled);
  }

  function scrollToTop(event) {
    event.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  }

  function cycleTheme() {
    const currentTheme = localStorage.theme || "system";

    switch (currentTheme) {
      case "light":
        localStorage.setItem("theme", "dark");
        toggleTheme(true);
        break;
      case "dark":
        localStorage.setItem("theme", "system");
        toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
        break;
      case "system":
      default:
        localStorage.setItem("theme", "light");
        toggleTheme(false);
        break;
    }
  }

  function toggleTheme(dark) {
    if (document.documentElement.classList.contains("dark") === dark) {
      return;
    }

    document.documentElement.classList.toggle("dark", dark);
  }

  function preloadTheme() {
    const userTheme = localStorage.theme;

    if (userTheme === "light" || userTheme === "dark") {
      toggleTheme(userTheme === "dark");
    } else {
      toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
    }
  }

  document.addEventListener("DOMContentLoaded", () => init());
  document.addEventListener("astro:after-swap", () => init());
  preloadTheme();

  const pageTitle = document.title;
  window.addEventListener("beforeprint", () => {
    if (document.title.includes("work")) {
      document.title = "Afonso Jorge Ramos - CV";
    }
  });
  window.addEventListener("afterprint", () => {
    document.title = pageTitle;
  });
</script>

<script defer is:inline src="https://analytics.afonsojramos.me/script.js" data-website-id="11e36fce-f071-4d77-a4eb-c085455454b6"></script>

---
import type { Concert } from "~/types/content";
import ConcertCarouselSolid from "./ConcertCarousel.tsx";

interface Props {
  concerts?: Concert[];
}

const { concerts } = Astro.props;

function optimizeCloudinaryImage(src: string): string {
  return src.replace(
    "/image/upload/",
    "/image/upload/c_fill,f_auto,h_540,q_auto,w_960/",
  );
}

const optimizedConcerts = concerts?.map((concert) => ({
  ...concert,
  optimizedImage: optimizeCloudinaryImage(concert.image),
  width: 960,
  height: 540,
}));
---

<ConcertCarouselSolid concerts={optimizedConcerts} client:only="solid-js" />

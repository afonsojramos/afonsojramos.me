---
import type { CollectionEntry } from "astro:content";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import Tags from "~/components/entries/Tags.astro";
import Link from "~/components/Link.astro";
import { dateRange } from "~/lib/utils";

interface Props {
  entry: CollectionEntry<"work"> & {
    Content: AstroComponentFactory;
  };
}

const { entry } = Astro.props;
---

<div class="flex">
  <div class="w-25 shrink-0 text-stone-400 dark:text-stone-400">
    {
      dateRange(entry.data.dateStart, entry.data.dateEnd).map((date) => (
        <p>{date}</p>
      ))
    }
  </div>
  <div class="flex flex-col print:break-after-avoid">
    <div class="flex flex-col flex-1">
      {
        entry.data.url ? (
          <Link href={entry.data.url} external>
            <h4>{entry.data.company}</h4>
          </Link>
        ) : (
          <h4>{entry.data.company}</h4>
        )
      }

      <p
        class="text-stone-800 dark:text-stone-100 print:text-stone-800 dark:print:text-stone-800"
      >
        {entry.data.role}
      </p>
    </div>

    <div class="content">
      <entry.Content />
    </div>

    <Tags tags={entry.data.tags} />
  </div>
</div>

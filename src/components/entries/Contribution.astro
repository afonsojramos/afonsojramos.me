---
import Link from "~/components/Link.astro";

interface Props {
  entry: {
    repository: string;
    url: string;
  };
}

const { entry } = Astro.props;
const [owner, ...repositoryParts] = entry.repository.split("/");
const repositoryName = repositoryParts.join("/");
---

<Link
  href={entry.url}
  external
  underline={false}
  class="group flex min-h-10 min-w-0 items-center py-1"
  aria-label={entry.repository}
>
  <span class="min-w-0 leading-tight">
    <span class="block truncate text-xs text-stone-400 dark:text-stone-400">{owner}</span>
    <span
      class="title-render block truncate text-black decoration-black/15 underline-offset-2 group-hover:underline dark:text-white dark:decoration-white/30"
    >
      {repositoryName}
    </span>
  </span>
</Link>

---
interface Props {
  placement?: "top" | "bottom";
}

const { placement = "top" } = Astro.props;
---

<span class="group/hovercard relative inline-flex">
  <slot />
  <span
    aria-hidden="true"
    class:list={[
      "pointer-events-none absolute left-1/2 z-50 w-64 -translate-x-1/2 rounded-xl bg-white p-3 text-left font-sans text-sm font-normal whitespace-normal text-black/60 normal-case no-underline opacity-0 shadow-[0_8px_30px_rgb(0_0_0/0.10)] ring-1 ring-black/5 transition-all duration-200 ease-out dark:bg-stone-800 dark:text-white/75 dark:ring-white/10",
      placement === "top"
        ? "bottom-full mb-2 translate-y-1"
        : "top-full mt-2 -translate-y-1",
      "group-hover/hovercard:pointer-events-auto group-hover/hovercard:translate-y-0 group-hover/hovercard:opacity-100",
    ]}
  >
    <slot name="card" />
  </span>
</span>

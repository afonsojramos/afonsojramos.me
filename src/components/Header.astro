---
import Container from "~/components/Container.astro";
import Link from "~/components/Link.astro";
import { SITE } from "~/consts";

const path = Astro.url.pathname;
const isActive = (prefix: string) => path === prefix || path.startsWith(`${prefix}/`);
const activeClass = "text-black dark:text-white";
---

<header class="print:hidden">
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href="/" underline={false}>
        <div class="font-semibold">
          {SITE.name}
        </div>
      </Link>
      <nav class="flex gap-1">
        <Link href="/blog" class={isActive("/blog") ? activeClass : ""}> blog </Link>
        <span>
          {`/`}
        </span>
        <Link href="/work" class={isActive("/work") ? activeClass : ""}> work </Link>
        <span>
          {`/`}
        </span>
        <Link href="/music" class={isActive("/music") ? activeClass : ""}> music </Link>
      </nav>
    </div>
  </Container>
</header>
